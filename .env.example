# ─────────────────────────────────────────────────────────────
# little-visitors — variables d'environnement (exemple)
#
# Copie ce fichier en `.env` et remplis les valeurs.
# ⚠️ Ne JAMAIS committer le fichier `.env` (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────

# Clé API eBird — https://ebird.org/api/keygen
# Sert à filtrer les espèces par région géographique.
EBIRD_API_KEY=your_ebird_api_key_here

# Région eBird ciblée (code régional), ex: FR, FR-OCC, US-NY...
EBIRD_REGION=FR

# Clé API du LLM générateur d'illustrations (Google Gemini par défaut)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Style des illustrations passé au prompt (voir docs/04-illustrations-llm.md)
ILLUSTRATION_STYLE=minimal flat vector illustration, soft pastel colors

# Chemin de la base SQLite de BirdNET-Pi sur le Pi
BIRDNET_DB_PATH=/home/pi/BirdNET-Pi/scripts/birds.db
